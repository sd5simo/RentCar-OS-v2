// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql" 
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")   // <-- ADD THIS LINE
}

model Client {
  id              String        @id @default(cuid())
  cin             String        @unique
  firstName       String
  lastName        String
  email           String?   @unique
  password        String?
  phone           String
  address         String?
  city            String?
  licenseNum      String?
  licenseExp      DateTime?
  isBlacklist     Boolean       @default(false)
  blacklistReason String?
  blacklistedAt   DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservations    Reservation[]
  rentals         Rental[]
  infractions     Infraction[]
}

model Vehicle {
  id              String        @id @default(cuid())
  make            String
  model           String
  registration    String        @unique
  year            Int
  dailyRate       Float
  mileage         Int?
  fuelType        String?
  transmission    String?
  imageUrl        String?
  status          String        @default("AVAILABLE")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  reservations    Reservation[]
  rentals         Rental[]
  damages         Damage[]
}

model Reservation {
  id          String    @id @default(cuid())
  clientId    String
  vehicleId   String
  startDate   DateTime
  endDate     DateTime
  totalPrice  Float     // Set as Float so parseFloat() works perfectly
  status      String    @default("PENDING") 
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client      Client    @relation(fields: [clientId], references: [id])
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Rental {
  id          String    @id @default(cuid())
  clientId    String
  vehicleId   String
  startDate   DateTime
  endDate     DateTime
  totalPrice  Float
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client      Client    @relation(fields: [clientId], references: [id])
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Damage {
  id          String    @id @default(cuid())
  vehicleId   String
  description String
  cost        Float?
  date        DateTime  @default(now())
  
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id          String    @id @default(cuid())
  amount      Float
  description String
  date        DateTime  @default(now())
  category    String
}

model Infraction {
  id          String    @id @default(cuid())
  clientId    String
  description String
  date        DateTime  @default(now())
  amount      Float?

  client      Client    @relation(fields: [clientId], references: [id])
}